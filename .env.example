# ─── Backend Environment Variables ────────────────────────────────────────────
# Copy this file to apps/backend/.env and fill in your real values.
# NEVER commit .env — it is listed in .gitignore.

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/subbee

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Nomba ─────────────────────────────────────────────────────────────────────
# OAuth2 client-credentials (TEST environment)
NOMBA_BASE_URL=https://sandbox.nomba.com
NOMBA_CLIENT_ID=your_test_client_id
NOMBA_CLIENT_SECRET=your_test_private_key
# Parent account ID — used in the accountId header on every API call
NOMBA_ACCOUNT_ID=your_parent_account_id
# Sub-account ID — for scoped operations
NOMBA_SUB_ACCOUNT_ID=your_sub_account_id
# HMAC Signature Key — from Nomba dashboard webhook configuration
NOMBA_WEBHOOK_SECRET=your_nomba_signature_key

# ── Bridgecard ────────────────────────────────────────────────────────────────
BRIDGECARD_BASE_URL=https://issuecards.api.bridgecard.co/v1/issuing/sandbox
BRIDGECARD_TOKEN=your_bridgecard_access_token
# AES-256 secret key for encrypting card PINs before sending to Bridgecard
BRIDGECARD_SECRET_KEY=your_bridgecard_secret_key
# Webhook verification (scheme TBD — verify from Bridgecard docs during integration)
BRIDGECARD_WEBHOOK_SECRET=your_bridgecard_webhook_secret
