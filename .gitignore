# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ─── Build outputs ────────────────────────────────────────────────────────────
dist/
build/
out/

# ─── Environment / secrets ────────────────────────────────────────────────────
# NEVER commit .env files — they contain API keys and private keys
.env
.env.local
.env.*.local

# ─── Editor / OS ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
pnpm-debug.log*

# ─── TypeScript cache ─────────────────────────────────────────────────────────
*.tsbuildinfo

# ─── Agent contracts (local-only) ────────────────────────────────────────────
# AGENTS.md files are read by AI agents for project context.
# They live on disk but are never committed — keeps GitHub clean and prevents
# accidental leaking of internal build instructions or credentials references.
AGENTS.md
